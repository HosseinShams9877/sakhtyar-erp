# ═══════════════════════════════════════════════════════
# ساختمان یار — پیکربندی محیطی (نمونه)
# Sakhteman Yar — Environment Configuration (Example)
# ═══════════════════════════════════════════════════════
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env     (Linux/macOS)
#   copy .env.example .env   (Windows)

# ─── دیتابیس (مسیر نسبی — در ویندوز و لینوکس کار می‌کند) ───
# SQLite for development — relative path from prisma/schema.prisma
DATABASE_URL=file:./db/custom.db

# ─── NextAuth (الزامی برای احراز هویت) ───
# Change the secret in production! Use a strong random string.
NEXTAUTH_SECRET=sakhteman-yar-erp-secret-key-2024-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── محیط اجرا ───
NODE_ENV=development
